  "claim_templates": {
    "economic_compensation": {
      "label": "经济补偿金",
      "source_anchors": [
        "LCL-2012#art38",
        "LCL-2012#art46",
        "LCL-2012#art47",
        "LCL-REG-2008#art27"
      ],
      "amount_rule": "average_monthly_wage_for_n * service_period_n",
      "evidence_needed": [
        "labor_contract_and_renewals",
        "twelve_month_wage_basis",
        "termination_characterization"
      ],
      "draft_note": "State years of service, monthly wage base, N months, and why economic compensation is triggered."
    },
    "unlawful_termination_compensation": {
      "label": "违法解除/终止赔偿金",
      "source_anchors": [
        "LCL-2012#art41",
        "LCL-2012#art43",
        "LCL-2012#art48",
        "LCL-2012#art87",
        "LCL-REG-2008#art25",
        "SPC-LDI-1-2020#art44"
      ],
      "amount_rule": "economic_compensation_n * 2",
      "evidence_needed": [
        "termination_notice_exact_reason",
        "layoff_threshold_and_plan",
        "thirty_day_explanation_opinion_report",
        "guangzhou_layoff_report_package",
        "priority_retention_and_rehire_evidence",
        "post_layoff_rehire_or_outsourcing_tracking",
        "rules_democratic_publication_proof",
        "misconduct_investigation_and_proportionality",
        "twelve_month_wage_basis"
      ],
      "draft_note": "Use when termination legality is disputed and worker claims 2N rather than only N; for economic layoffs, bind the threshold, explanation/opinion/reporting, priority-retention, local report-package gaps, and six-month rehire or replacement facts instead of relying on fault-dismissal evidence."
    },
    "substitute_notice_wage": {
      "label": "代通知金",
      "source_anchors": [
        "LCL-2012#art40",
        "LCL-REG-2008#art20"
      ],
      "amount_rule": "previous_month_wage",
      "evidence_needed": [
        "article40_ground_evidence",
        "notice_or_substitute_wage_evidence"
      ],
      "draft_note": "Only use for eligible non-fault dismissal without 30-day advance notice."
    },
    "unpaid_wages": {
      "label": "拖欠工资",
      "source_anchors": [
        "LCL-2012#art30",
        "LCL-2012#art85",
        "LDA-2007#art2"
      ],
      "amount_rule": "sum_of_unpaid_wages",
      "evidence_needed": [
        "payroll_tax_social_insurance_records",
        "work_access_and_attendance_records",
        "unpaid_wage_or_social_insurance_gap"
      ],
      "draft_note": "List wage months, due dates, paid amounts, and unpaid balance."
    },
    "unused_annual_leave": {
      "label": "未休年休假工资差额",
      "source_anchors": [
        "PAID-LEAVE-REG-2007#art5",
        "PAID-LEAVE-MEASURES-2008#art10",
        "PAID-LEAVE-MEASURES-2008#art11",
        "LDA-2007#art2",
        "LDA-2007#art6"
      ],
      "amount_rule": "unused_leave_days * daily_wage * statutory_multiplier_delta",
      "evidence_needed": [
        "attendance_and_leave_records",
        "twelve_month_wage_basis"
      ],
      "draft_note": "Local annual leave rules must be verified before final filing."
