      "label": "竞业限制经济补偿",
      "source_anchors": [
        "LCL-2012#art23",
        "SPC-LDI-1-2020#art36",
        "SPC-LDI-1-2020#art37",
        "SPC-LDI-1-2020#art38"
      ],
      "amount_rule": "agreed_amount_or_30_percent_average_wage_floor_checked * performance_months",
