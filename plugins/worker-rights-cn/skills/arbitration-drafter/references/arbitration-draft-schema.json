        "salary_cut_transfer_objection",
        "pregnancy_or_medical_status_proof",
        "payroll_tax_social_insurance_records"
      ],
      "draft_note": "Use necessary and redacted sensitive proof; verify whether medical proof supported any workload adjustment."
