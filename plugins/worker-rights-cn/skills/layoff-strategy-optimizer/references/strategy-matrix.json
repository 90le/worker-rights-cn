  "schema_version": "0.1.0",
  "retrieved_at": "2026-06-16",
  "source_note": "Strategy matrix for lawful worker-side recovery optimization in enterprise layoff and dismissal scenarios. Use with layoff-defense legal-map, compensation-calculator, local-rules-adapter, evidence-builder, negotiation-coach, agreement-review, arbitration-drafter, and safety-guardrails.",
  "global_principles": [
    "Maximize lawful expected recovery, not unsupported theoretical numbers.",
    "Preserve the strongest factual characterization before signing resignation, waiver, settlement, or handover documents.",
    "Separate confirmed claims from upside items that need more evidence.",
    "Use negotiation while leverage is high, but switch to arbitration when limitation, payment default, evidence loss, or refusal to give written terms becomes material.",
    "Do not fabricate evidence, threaten exposure, copy company secrets, publish personal information, or guarantee outcomes."
  ],
  "strategy_priority": [
    "safety_screen",
    "classification_preservation",
    "evidence_sprint",
    "lawful_value_stack",
    "local_rule_check",
    "negotiation_or_agreement_review",
    "arbitration_filing"
  ],
  "settlement_floor_rules": {
    "valid_mutual_or_economic_layoff": "N plus all unpaid statutory and contractual items, with local cap and wage base verified.",
    "valid_non_fault_without_notice": "N + substitute notice wage where LCL art.40 applies and 30-day notice is missing.",
    "unlawful_termination": "Compare reinstatement and 2N; do not double count N and 2N for the same termination.",
    "forced_resignation_with_employer_breach": "N triggered by art.38 facts plus unpaid wages/benefits if evidence supports them.",
    "pre_signing_negotiation": "Ask above the floor when employer wants speed, waiver, non-disparagement, confidentiality, non-compete, reference wording, or broad release."
  },
